# ==========================================
# GO BINARIES — the main fix needed
# ==========================================

# The compiled binary that was accidentally committed
/api
/cmd/api/api
/cmd/api/driftguard

# All Go binaries generally
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binaries
*.test
*.out

# Go build cache
/vendor/

