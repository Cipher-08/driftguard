# ==========================================================================
# DriftGuard configuration. Copy to `.env` and fill in what you need.
#   cp .env.example .env
# Everything has a sensible default for local development except secrets.
# ==========================================================================

# ---- Server ----
PORT=8080
ENVIRONMENT=development

# ---- Database (Postgres) ----
# For docker compose these are derived automatically; override only if needed.
POSTGRES_USER=driftguard
POSTGRES_PASSWORD=driftguard
POSTGRES_DB=driftguard
DATABASE_URL=postgres://driftguard:driftguard@localhost:5432/driftguard?sslmode=disable

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Auth ----
# CHANGE THIS in production (required when ENVIRONMENT=production).
JWT_SECRET=change-me-in-production-please
JWT_EXPIRY_HOURS=24

# ---- AWS (optional: you can also add credentials per-org via the UI) ----
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---- GCP (optional: usually added per-org via the UI as a service-account JSON) ----
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# ---- GitHub (optional: enables one-click remediation PRs) ----
# Personal access token with `repo` scope.
GITHUB_TOKEN=

# ==========================================================================
# AI remediation — 100% free, pluggable. Set ONE of the following.
# DriftGuard auto-detects which provider to use; none is also fine
# (everything else works, the AI "generate fix" step just stays idle).
# ==========================================================================

# Optional explicit override: groq | gemini | ollama
LLM_PROVIDER=

# Groq — free API key at https://console.groq.com (fast, recommended)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini — free tier at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Ollama — fully local, no signup (https://ollama.com). e.g. http://localhost:11434
OLLAMA_HOST=
OLLAMA_MODEL=llama3.1
